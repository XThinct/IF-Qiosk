# Konfigurasi Port Server
PORT=8000

# Konfigurasi Database PostgreSQL
DB_HOST=localhost
DB_USER=postgres
DB_PASS=your_postgres_password
DB_NAME=your_database_name
DB_PORT=5432

# Minimal 32 characters
JWT_SECRET=replace_with_a_long_random_secret
FRONTEND_URL=http://localhost:5173

# Public URLs for cross-network QR code access (e.g. ngrok tunnels).
# Leave unset to use local IP (same-WiFi mode).
# PUBLIC_BACKEND_URL=https://your-backend-tunnel.ngrok.io
# PUBLIC_FRONTEND_URL=https://your-frontend-tunnel.ngrok.io

# Environment
NODE_ENV=development
DB_LOGGING=false